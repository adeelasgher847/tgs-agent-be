{
  "family": "tgs-api-task",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "<IMAGE>",
      "cpu": 256,
      "memory": 512,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8001,
          "hostPort": 8001,
          "protocol": "tcp"
        }
      ],
      "command": [
        "python3",
        "-m",
        "uvicorn",
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8001"
      ],
      "environment": [
        { "name": "ENVIRONMENT", "value": "production" },
        { "name": "DATABASE_URL", "value": "" },
        { "name": "REDIS_URL", "value": "" },
        { "name": "SECRET_KEY", "value": "" },
        { "name": "OPENAI_API_KEY", "value": "" },
        { "name": "DEEPGRAM_API_KEY", "value": "" },
        { "name": "ELEVENLABS_ENCRYPTION_KEY", "value": "" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tgs-api-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole"
}
