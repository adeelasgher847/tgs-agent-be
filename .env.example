# Copy this file to .env and fill in real values. Never commit .env.
#
# For a full on-premise Docker Compose deployment, see docs/on-premise/README.md
# — it documents the subset of these variables that the bundled compose stack
# actually requires, plus the BYO LLM/TTS/telephony switches below.

# Database
# Host "postgres" is the named Docker Compose service (see docker-compose.yml).
# Running app/uvicorn outside Docker against the same stack? Use "localhost" instead.
# NOTE: DATABASE_URL's password is a separate plain string from POSTGRES_PASSWORD
# below (.env files are not variable-interpolated) — if you change one, change both.
DATABASE_URL=postgresql+psycopg2://postgres:change-me-strong-password@postgres:5432/voiceagent

# Postgres container init vars (only read by the official `postgres` image itself,
# not by the app — must match the credentials embedded in DATABASE_URL above).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=voiceagent

# JWT
SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment — controls Twilio test-credential switching and GCP Secret Manager
# usage (app/core/secret_manager.py). On-premise deployments should set this to
# "production" AND leave GCP_PROJECT_ID blank: with no project ID the app skips
# Secret Manager entirely and reads every secret straight from this .env file.
ENVIRONMENT=production

# Internal webhook auth — required for batch calls + Smart Callback Scheduler
# outbound dispatch (app/services/batch_call_worker_service.py::_build_fake_request).
N8N_WEBHOOK_SECRET=<generate with: python -c "import secrets; print(secrets.token_hex(32))">

# ===========================================================================
# BYO (Bring Your Own) provider configuration — on-premise data-sovereignty.
# Each switch below is a deployment-wide default; see app/core/config.py for
# the full BYO settings block and docs/on-premise/README.md for the reference.
# ===========================================================================

# --- BYO LLM ---------------------------------------------------------------
# LLM_PROVIDER: 'google' (Gemini/Vertex AI) | 'openai' | 'azure_openai'
LLM_PROVIDER=google
# Required when LLM_PROVIDER=openai or azure_openai.
OPENAI_API_KEY=
# Point the OpenAI SDK at Azure OpenAI or any Ollama/vLLM/LiteLLM
# OpenAI-compatible endpoint instead of api.openai.com. Leave blank for the
# real OpenAI API.
#   Azure OpenAI example: https://my-resource.openai.azure.com
#   Ollama example:       http://ollama:11434/v1
OPENAI_BASE_URL=
# Required when LLM_PROVIDER=azure_openai (Azure's REST API version).
OPENAI_API_VERSION=2024-10-21
# Required when LLM_PROVIDER=google.
GEMINI_API_KEY=

# --- BYO TTS -----------------------------------------------------------------
# TTS_PROVIDER: 'rime' | 'elevenlabs'
TTS_PROVIDER=elevenlabs
# Generic BYO key — auto-applied to RIME_API_KEY/ELEVENLABS_API_KEY below
# (whichever TTS_PROVIDER selects) when that provider-specific var is unset.
# Set either this OR the provider-specific key directly, not both.
TTS_API_KEY=
ELEVENLABS_API_KEY=
RIME_API_KEY=
# Symmetric encryption key for agent.encrypted_elevenlabs_api_key (pgp_sym_encrypt).
ELEVENLABS_ENCRYPTION_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">

# --- HubSpot CRM integration ---------------------------------------------------
# OAuth app credentials from https://developers.hubspot.com/. In staging/production
# these are read from Secret Manager (see app/core/secret_manager.py); these env
# vars are local-dev fallbacks only.
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
# Must exactly match the redirect URI configured on the HubSpot app. Defaults to
# {WEBHOOK_BASE_URL}/api/v1/integrations/hubspot/callback when unset.
HUBSPOT_REDIRECT_URI=
# Symmetric encryption key for workspaceintegration.access_token/refresh_token (AES-256-GCM).
# MUST be a randomly generated 32-byte secret (represented as a 64-character hex string).
# Preserve compatibility with existing encrypted tokens by keeping the key unchanged.
HUBSPOT_TOKEN_ENCRYPTION_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">

# --- BYO telephony -----------------------------------------------------------
# TELEPHONY_PROVIDER: 'twilio' | 'sip'
TELEPHONY_PROVIDER=twilio
# Required when TELEPHONY_PROVIDER=twilio.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+15551234567
# Required when TELEPHONY_PROVIDER=sip — your own SIP trunk, registered per
# number via POST /api/v1/phone-numbers/external (app/services/phone_number_service.py).
SIP_TRUNK_URI=sip:trunk.example.com
SIP_USERNAME=
SIP_PASSWORD=

# ===========================================================================
# Everything below is unchanged from cloud/SaaS deployments.
# ===========================================================================

# Deepgram (default STT)
DEEPGRAM_API_KEY=

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_INCALL_WEBHOOK_SECRET=whsec_...
PAYMENT_PAGE_BASE_URL=https://pay.yourdomain.com

# Google / OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Cloud TTS + STT (Application Default Credentials)
# Set to the path of a service-account JSON key file, OR export the JSON content
# directly as the env var value.  Used for both google-cloud-texttospeech and
# google-cloud-speech (ADC — no per-call key file required).
GOOGLE_APPLICATION_CREDENTIALS=

# GCP Secret Manager project ID. Leave BLANK for on-premise deployments — see
# the ENVIRONMENT note above. Only set this if you run your own GCP project.
GCP_PROJECT_ID=

# Pinecone (RAG vector store)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=voiceagent-kb

# SendGrid
SENDGRID_API_KEY=

# Redis — in Docker Compose, host "redis" is the named service.
REDIS_URL=redis://redis:6379

# Anthropic (for AI review agent — optional, CI only)
ANTHROPIC_API_KEY=

# LiveKit (self-hosted real-time audio transport). In Docker Compose, host
# "livekit" is the named service on the internal network — see docker-compose.yml.
LIVEKIT_URL=http://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=<generate with: python -c "import secrets; print(secrets.token_urlsafe(32))">
LIVEKIT_TOKEN_TTL=3600
LIVEKIT_ROOM_EMPTY_TIMEOUT=30
LIVEKIT_MAX_PARTICIPANTS=2
LIVEKIT_ENABLED=true

# STT (Speech-to-Text)
# Silence threshold: how long (ms) without audio before treating utterance as complete.
# Used by GoogleSttService and Deepgram path alike.
SILENCE_THRESHOLD_MS=1500
# STT latency SLO (ticket: speech end → final transcript p95 < 400ms in staging)
STT_P95_THRESHOLD_MS=400

# NOTE: Google STT requires ffmpeg. The bundled Docker image already includes
# a static ffmpeg binary (see Dockerfile) — only needed for bare-metal/non-Docker
# installs:
#   Linux:  apt-get install -y ffmpeg
#   macOS:  brew install ffmpeg
# ffmpeg is used by LiveKitAudioProcessor to resample non-16kHz PCM → LINEAR16.

# Live Google STT integration tests (optional local/staging):
#   RUN_GOOGLE_STT_INTEGRATION=1 pytest tests/integration/test_google_stt_live.py -v
# Staging p95 enforcement (p95 < 400ms):
#   STT_STRICT_LATENCY=1 RUN_GOOGLE_STT_INTEGRATION=1 pytest tests/integration/test_google_stt_live.py -v
# Staging log analysis after test calls:
#   python scripts/stt_latency_p95.py --log app.log --threshold 400
# GOOGLE_APPLICATION_CREDENTIALS supports inline JSON or a file path (local dev).

# Server
DEBUG=False
HOST=0.0.0.0
PORT=8001
WEBHOOK_BASE_URL=https://your-domain.com

# API docs (Swagger UI at /api/docs) — HTTP Basic auth.
API_DOCS_ENABLED=true
API_DOCS_USERNAME=admin
API_DOCS_PASSWORD=<generate a strong password>

# Outbound call concurrency limit per workspace (default: 10)
OUTBOUND_MAX_CONCURRENT_PER_WORKSPACE=10

# GCS Call Recordings (Sprint 4) — optional; leave blank to disable recording upload.
# Service account credentials are loaded from GOOGLE_APPLICATION_CREDENTIALS (ADC).
# The service account must have roles/storage.objectCreator + roles/storage.objectViewer on the bucket.
GCS_RECORDINGS_BUCKET=
GCS_RECORDINGS_SIGNED_URL_EXPIRY_SECONDS=3600
GCS_RECORDINGS_PREFIX=recordings
# Infra: apply a GCS lifecycle rule to delete objects older than 90 days under the recordings/ prefix.
# Sprint 5 (HIPAA): set CMEK encryption key for the bucket (customer-managed encryption).

# AWS S3 storage (GCS → S3 migration) — optional; leave blank to disable S3 upload.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1
S3_RECORDINGS_BUCKET=
S3_KB_BUCKET=

# nginx-proxy — self-signed cert is generated at image build time
# (nginx/ssl/). To use a real certificate, see docs/on-premise/README.md.
NGINX_SERVER_NAME=localhost

# Images used by docker-compose.yml. Defaults build+tag locally via
# `docker compose up --build`. For the packaged tar.gz deliverable (no
# source included), set these to the Artifact Registry path:tag CI
# published, e.g.:
#   APP_IMAGE=us-docker.pkg.dev/<project>/<repo>/tgs-agent-be:1.4.0
#   NGINX_IMAGE=us-docker.pkg.dev/<project>/<repo>/tgs-agent-be-nginx:1.4.0
# then `docker compose pull && docker compose up -d` (no --build).
APP_IMAGE=tgs-agent-be:local
NGINX_IMAGE=tgs-agent-be-nginx:local
